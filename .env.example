# Neon Database Connection String
# Obtenha sua connection string em: https://console.neon.tech/
# Formato: postgresql://user:password@host/database?sslmode=require
VITE_DATABASE_URL=postgresql://user:password@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require

# Cloudinary (Para upload de imagens)
# Obtenha em: https://cloudinary.com/console
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Facebook Pixel (Para tracking e analytics)
# Obtenha em: https://business.facebook.com/events_manager
VITE_FACEBOOK_PIXEL_ID=your_pixel_id

# Facebook Conversions API (Server-side tracking)
# Obtenha em: https://business.facebook.com/events_manager -> Configurações -> Conversions API
FACEBOOK_CONVERSIONS_API_TOKEN=your_conversions_api_access_token
